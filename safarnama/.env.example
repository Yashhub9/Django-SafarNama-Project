# Django
DJANGO_SECRET_KEY=replace-this-with-a-strong-secret-key
DEBUG=False
ALLOWED_HOSTS=yourusername.pythonanywhere.com,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com
TIME_ZONE=Asia/Kolkata

# Database
# Use sqlite for the easiest PythonAnywhere deployment.
DB_ENGINE=sqlite
DATABASE_URL=

# If you want MySQL later, switch DB_ENGINE to mysql and fill these:
# DB_NAME=your_pythonanywhere_db_name
# DB_USER=your_pythonanywhere_db_user
# DB_PASSWORD=your_pythonanywhere_db_password
# DB_HOST=your_pythonanywhere_mysql_host
# DB_PORT=3306

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
